{
"manifest_version":3,
"name":"SentinelAI Scam Shield",
"version":"1.0",

"permissions":[
"tabs"
],

"host_permissions":[
"<all_urls>",
"http://127.0.0.1:5000/*"
],

"background":{
"service_worker":"background.js"
},

"content_scripts":[
{
"matches":["<all_urls>"],
"js":["content.js"],
"css":["style.css"],
"run_at":"document_start"
}
]
}